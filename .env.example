# Smart Parking System Environment Variables

# Local development uses SQLite by default.
# For Railway Postgres deployment, set:
# DATABASE_URL=postgresql://user:password@host:port/dbname
# Railway will automatically inject this from the Postgres plugin.

# Optional: Override PORT (default 5000)
# PORT=5000

# App auth secret
# SECRET_KEY=change-this-secret-in-production

# Frontend redirect after OAuth login
# FRONTEND_APP_URL=/app

# Google OAuth
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback

# Apple OAuth
# APPLE_CLIENT_ID=your-apple-service-id
# APPLE_CLIENT_SECRET=your-apple-client-secret
# APPLE_REDIRECT_URI=http://localhost:5000/auth/apple/callback

# Mobile money
# PAYSTACK_SECRET_KEY=sk_test_or_live_key
